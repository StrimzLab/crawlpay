# =============================================================================
# CrawlPay environment template
#
# Copy to .env and fill the empty fields. Verified contract addresses are
# pre-populated. Never commit .env.
# =============================================================================

# ─── Runtime ────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ─── Arc Testnet network ────────────────────────────────────
# Arc uses USDC as the native gas token — no separate gas asset needed.
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_RPC_WS_URL=wss://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_EXPLORER_URL=https://testnet.arcscan.app
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000

# ─── Circle Gateway contracts on Arc Testnet ────────────────
# Source: developers.circle.com/gateway/references/contract-addresses
# GatewayWallet is the `verifyingContract` for EIP-712 payment signing.
ARC_GATEWAY_WALLET_ADDRESS=0x0077777d7EBA4688BDeF3E311b846F25870A19B9
ARC_GATEWAY_MINTER_ADDRESS=0x0022222ABE238Cc2C7Bb1f21003F0a260052475B

# ─── Circle Gateway SDK ─────────────────────────────────────
# SupportedChainName for @circle-fin/x402-batching
CRAWLPAY_NETWORK=arcTestnet

# ─── ERC-8004 registries on Arc Testnet ─────────────────────
# Source: docs.arc.io — "Register your first AI agent" tutorial
ERC8004_IDENTITY_REGISTRY=0x8004A818BFB912233c491871b3d84c89A494BD9e
ERC8004_REPUTATION_REGISTRY=0x8004B663056A597Dffe9eCcC1965A193B7388713
ERC8004_VALIDATION_REGISTRY=0x8004Cb1BF31DAf7788923b405b754f57acEB4272

# ─── Crawler wallet (buyer EOA — you control the key) ──────
# Generate:  cast wallet new
# Fund:      https://faucet.circle.com  →  Arc Testnet  →  paste CRAWLER_ADDRESS
# Gateway requires EOA (ecrecover); no SCA / smart-contract accounts.
CRAWLER_PRIVATE_KEY=
CRAWLER_ADDRESS=

# ─── Publisher wallet (seller — only the address is needed) ──
# Generate another fresh EOA; address-only is fine for the publisher side.
PUBLISHER_ADDRESS=

# ─── CrawlPay facilitator ───────────────────────────────────
# Thin wrapper around Circle's BatchFacilitatorClient that adds
# CrawlPay receipt signing, bot classification, and persistence.
FACILITATOR_PORT=3001

# ECDSA private key used ONLY for signing CrawlPay receipts.
# Not a wallet — holds no funds. Generate with `cast wallet new` and never fund it.
CRAWLPAY_RECEIPT_PRIVATE_KEY=

# ─── API gateway + persistence ──────────────────────────────
API_PORT=8080
DATABASE_URL=
REDIS_URL=

# ─── Web dashboard ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_FACILITATOR_URL=http://localhost:3001
NEXT_PUBLIC_ARC_EXPLORER_URL=https://testnet.arcscan.app

# ─── Demo / smoke test ──────────────────────────────────────
# Port for the local demo publisher server.
DEMO_PUBLISHER_PORT=4000
# Default per-request price in atomic USDC (6 decimals).
# 100 = $0.0001 · 1000 = $0.001 · 10000 = $0.01
DEMO_DEFAULT_PRICE_ATOMIC=100
# Optional comma-separated publisher addresses for the multi-publisher demo session.
# Leave blank for the smoke test (uses PUBLISHER_ADDRESS).
DEMO_PUBLISHER_ADDRESSES=
